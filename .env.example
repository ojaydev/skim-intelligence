# ─── Anthropic ───
# Required — powers Alpha, Risk, and Reporter agents.
ANTHROPIC_API_KEY=

# ─── Bayse (market data) ───
# Docs: https://docs.bayse.markets/authentication
# HMAC-SHA256 on {timestamp}.{METHOD}.{path}.{sha256_hex(body)} → base64 digest
BAYSE_PUBLIC_API_KEY=
BAYSE_API_SECRET=

# ─── Clerk (user auth — optional, gates /api/wallet/*) ───
# Frontend needs the publishable key; Worker needs the secret.
# Vite picks up VITE_CLERK_PUBLISHABLE_KEY at build time (see apps/web/.env.local).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Paystack (deposits + payouts — optional) ───
# Test keys work for init + webhook; transfers (payouts) need a fully activated business.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── HTTP CONNECT proxy (optional workaround for Bayse WAF) ───
# Format: http://user:pass@host:port — a residential/Nigerian egress bypasses
# Bayse's block on Cloudflare Workers IPs. Note: CF Workers' startTls SNI
# limitation makes TCP-socket tunneling unreliable. Prefer the relay below.
PROXY_URL=

# ─── Bayse relay (production fix for Bayse WAF block) ───
# Generate: openssl rand -hex 32
# Set the same value here AND in apps/relay/.env. When set, the worker
# rejects /api/admin/bayse/seed and /api/bayse/orderbook requests that
# don't carry a matching X-Relay-Auth header. See apps/relay/README.md.
RELAY_SECRET=

# ─── Cloudflare (deploy only; not runtime secrets) ───
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
