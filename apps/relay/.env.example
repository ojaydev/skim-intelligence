# ─── Required ─────────────────────────────────────────────────────────
# Bayse HMAC credentials — same values used by the worker.
BAYSE_PUBLIC_API_KEY=
BAYSE_API_SECRET=

# Skim worker URL (no trailing slash).
WORKER_URL=https://skim-intelligence.<account>.workers.dev

# Shared secret with the worker. Set the same value via:
#   wrangler secret put RELAY_SECRET
# Generate with:  openssl rand -hex 32
RELAY_SECRET=

# ─── Optional ─────────────────────────────────────────────────────────
# Top-N markets to subscribe to (Bayse caps at 10 per subscribe).
MAX_MARKETS=10

# How often to refresh the event seed in KV (minutes). Min 5.
SEED_REFRESH_MINUTES=30

# /healthz HTTP port for monitoring.
HEALTH_PORT=3000

# Per-market debounce (ms). Drops intermediate frames within this window
# to avoid Cloudflare KV "1 write per second per key" throttling.
FRAME_DEBOUNCE_MS=500
