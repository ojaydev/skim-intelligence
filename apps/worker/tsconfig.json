{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@skim/shared": ["../../packages/shared/src/index.ts"],
      "@skim/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "worker-configuration.d.ts"]
}
