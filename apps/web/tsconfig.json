{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@skim/shared": ["../../packages/shared/src/index.ts"],
      "@skim/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
